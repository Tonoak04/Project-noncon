{
  "hosting": {
    "public": "public/php/frontend/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "predeploy": [
      "npm --prefix public/php/frontend install",
      "npm --prefix public/php/frontend run build"
    ]
  }
}
