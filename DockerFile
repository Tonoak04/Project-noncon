FROM php:8.2-apache

# เปิด mod_rewrite
RUN a2enmod rewrite

# ติดตั้ง system packages + Node.js 20 LTS สำหรับ build React frontend
RUN apt-get update \
    && apt-get install -y curl ca-certificates gnupg git unzip libzip-dev \
    && mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] https://deb.nodesource.com/node_20.x nodistro main" > /etc/apt/sources.list.d/nodesource.list \
    && apt-get update \
    && apt-get install -y nodejs \
    && docker-php-ext-configure zip \
    && docker-php-ext-install mysqli pdo_mysql zip \
    && rm -rf /var/lib/apt/lists/*

# ติดตั้ง Composer
ENV COMPOSER_ALLOW_SUPERUSER=1
RUN php -r "copy('https://getcomposer.org/installer', 'composer-setup.php');" \
    && php composer-setup.php --install-dir=/usr/local/bin --filename=composer \
    && php -r "unlink('composer-setup.php');"

# ตั้ง working directory
WORKDIR /var/www/html

# ติดตั้ง custom entrypoint สำหรับรัน npm install/build อัตโนมัติ
COPY docker-entrypoint.sh /usr/local/bin/project-entrypoint.sh
RUN chmod +x /usr/local/bin/project-entrypoint.sh

ENTRYPOINT ["project-entrypoint.sh"]
CMD ["apache2-foreground"]
